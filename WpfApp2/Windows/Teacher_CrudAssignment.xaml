<Window x:Class="WpfApp2.StudentAssignmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Assignments" Height="450" Width="700" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtStudentName" FontWeight="Bold" FontSize="16"/>

        <DataGrid Grid.Row="1" x:Name="DgAssignments" 
                  SelectionChanged="DgAssignments_SelectionChanged" IsReadOnly="True" AutoGeneratingColumn="DgAssignments_AutoGeneratingColumn">

        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnAdd" Content="Add" Width="80" Click="AddAssignment_Click"/>
            <Button x:Name="BtnUpdate" Content="Update" Width="80" Margin="6,0,0,0" Click="UpdateAssignment_Click"/>
            <Button x:Name="BtnDelete" Content="Delete" Width="80" Margin="6,0,100,0" Click="DeleteAssignment_Click"/>
           


        </StackPanel>
    </Grid>
</Window>