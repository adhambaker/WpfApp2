<Window x:Class="WpfApp2.AddEditAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Teacher Update Assignment" Height="224" Width="459" >
    <Grid >


        <Label Content="Title" HorizontalAlignment="Left" Margin="40,34,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtBoxOfTitle" HorizontalAlignment="Left" Margin="142,42,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>

        <Label Content="Description" HorizontalAlignment="Left" Margin="40,78,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtBoxOfDesc" HorizontalAlignment="Left" Margin="142,86,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="230" Height="32"/>

        <Label Content="Status" HorizontalAlignment="Left" Margin="40,135,0,0" VerticalAlignment="Top"/>




        <Button Content="Save" HorizontalAlignment="Center" Margin="0,178,0,0" VerticalAlignment="Top" Width="55" Click="Button_Click"/>
        <ComboBox x:Name="CmbOfStatus" HorizontalAlignment="Left" Margin="142,139,0,0" VerticalAlignment="Top" Width="120">

            <ComboBoxItem Content="Pending"/>
            <ComboBoxItem Content="In Progress"/>
            <ComboBoxItem Content="Done"/>
        </ComboBox>


    </Grid>
</Window>
