<Window x:Class="StudentTaskSystem.Windows.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentTaskSystem.Windows"
        mc:Ignorable="d"
        Title="StudentWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <DataGrid x:Name="GdStudent"  Height="295" Width="800" SelectionChanged="GdStudent_SelectionChanged" IsReadOnly="True" AutoGeneratingColumn="GdStudent_AutoGeneratingColumn" />
            <Button Content="Update Status" Click="UpdateStatus_Click"/>
            <Button Content="Logout"  Click="logout_button"/>
        </StackPanel>

    </Grid>
</Window>
