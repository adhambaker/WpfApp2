<Window x:Class="StudentTaskSystem.Windows.Student_UpdateStatus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentTaskSystem.Windows"
        mc:Ignorable="d"
        Title="Student_UpdateStatus" >
    <Grid>

        <Label Content="Status"  Margin="42,30,504,377" />
        <ComboBox x:Name="CmbStatus" Margin="144,30,374,377" RenderTransformOrigin="0.5,0.5" >
            <ComboBoxItem Content="Pending"/>
            <ComboBoxItem Content="In Progress"/>
            <ComboBoxItem Content="Done"/>
        </ComboBox>
        <Button Content="Save" HorizontalAlignment="Left" Margin="84,83,0,324"  Click="Save_Click" Width="56"/>

    </Grid>
</Window>
