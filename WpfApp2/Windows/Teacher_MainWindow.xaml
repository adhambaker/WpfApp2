<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher - Students" Height="540" Width="880" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="8" VerticalAlignment="Top">
            <TextBlock Text="Student Name"/>
            <TextBox x:Name="TextBoxOfName"/>

            <TextBlock Text="Age" Margin="0,8,0,0"/>
            <TextBox x:Name="TextBoxOfAge"/>

            <TextBlock Text="Username" Margin="0,8,0,0"/>
            <TextBox x:Name="TextBoxUser"/>

            <TextBlock Text="Password" Margin="0,8,0,0"/>
            <TextBox x:Name="TextBoxPass"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Add" Width="80" Margin="6,0,20,0" Click="Add_Button_Click"/>
                <Button Content="Update" Width="80" Margin="6,0,20,0" Click="Update_Button_Click"/>
                <Button Content="Delete" Width="80" Margin="6,0,20,0" Click="Delete_Button_Click"/>
            </StackPanel>

            <Separator Margin="0,10,0,10"/>

            <Button Content="Show Selected Assignments" Width="220" Click="ShowAssignments_Click"/>
            <Button Content="Show All Assignments" Width="220" Margin="0,6,0,0" Click="ShowAllAssignments_Click"/>

            <Button Content="Log out" Width="120" Margin="0,12,0,0" Click="LogOut_Click" FontWeight="Bold"/>
        </StackPanel>

        <DataGrid x:Name="DgStudent" Grid.Column="1" 
           SelectionChanged="DgStudent_SelectionChanged" IsReadOnly="True" AutoGeneratingColumn="DgStudent_AutoGeneratingColumn">

        </DataGrid>
    </Grid>
</Window>
